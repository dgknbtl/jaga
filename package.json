{
  "name": "jagajs",
  "version": "1.4.1",
  "description": "The ultimate ultra-lightweight, context-aware security engine for HTML templates. Zero-dependency XSS protection for modern web apps.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dgknbtl/jaga.git"
  },
  "bugs": {
    "url": "https://github.com/dgknbtl/jaga/issues"
  },
  "homepage": "https://github.com/dgknbtl/jaga#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./sanitize": {
      "types": "./dist/sanitize.d.ts",
      "import": "./dist/sanitize.js",
      "require": "./dist/sanitize.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "showcase": "vite showcase",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "xss",
    "xss-protection",
    "security",
    "html-sanitizer",
    "sanitize",
    "template",
    "tagged-templates",
    "html",
    "trusted-types",
    "csp-nonce",
    "ssr",
    "zero-dependency",
    "vanilla-js"
  ],
  "author": "Dogukan Batal <dogukanbatal@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.13.9",
    "happy-dom": "^17.1.8",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.7"
  }
}
